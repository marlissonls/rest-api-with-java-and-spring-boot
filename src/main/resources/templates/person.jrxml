	<query language="SQL"><![CDATA[SELECT id,
	CONCAT(first_name, ' ',	last_name) AS name,
	address,
	gender,
	enabled,
	wikipedia_profile_url AS profileUrl,
	photo_url AS photoUrl
FROM rest_with_spring_boot.person
WHERE 
	id = $P{PERSON_ID}
]]></query>
